{
  "openapi": "3.0.3",
  "info": {
    "title": "API REST - MANEX",
    "description": "API de MANEX para la gestión de empleados, departamentos, contratos e inventario...",
    "version": "1.3.1"
  },
  "servers": [
    {
      "url": "http://localhost:80",
      "description": "Servidor local de desarrollo"
    }
  ],
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "token",
        "description": "Token de autenticación obtenido al iniciar sesión."
      }
    },
    "schemas": {
      "ErrorBadRequest": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "example": 400 },
          "message": { "type": "string", "example": "Parámetros inválidos o nulos" }
        }
      },
      "ErrorUnauthorized": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "example": 401 },
          "message": { "type": "string", "example": "Token caducado o inexistente" }
        }
      },
      "ErrorForbidden": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "No tienes permiso para esta acción" }
        }
      },
      "ErrorNotFound": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "example": 404 },
          "message": { "type": "string", "example": "Recurso no encontrado" }
        }
      },
      "ErrorServer": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "example": 500 },
          "message": { "type": "string", "example": "Error en el servidor" }
        }
      },
      "Empleado": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "Nombre": { "type": "string", "example": "Juan" },
          "Apellidos": { "type": "string", "example": "García López" },
          "fecha_nacimiento": { "type": "string", "format": "date", "example": "1990-05-15" },
          "telefono": { "type": "string", "example": "612345678" },
          "ID_CONTRATO": { "type": "integer", "example": 3 },
          "ID_DEPARTAMENTO": { "type": "integer", "example": 2 },
          "username": { "type": "string", "example": "jgarcia" },
          "esVisible": { "type": "integer", "example": 1 }
        }
      },
      "Contrato": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer", "example": 1 },
          "Salario_anual": { "type": "number", "example": 24000 },
          "Horas_anuales": { "type": "number", "example": 1800 }
        }
      },
      "Departamento": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer", "example": 1 },
          "Nombre": { "type": "string", "example": "Recursos Humanos" }
        }
      },
      "Producto": {
        "type": "object",
        "properties": {
          "ID": { "type": "integer", "example": 1 },
          "nombre": { "type": "string", "example": "Teclado mecánico" }
        }
      }
    }
  },
  "security": [
    { "tokenAuth": [] }
  ],
  "tags": [
    { "name": "General", "description": "Endpoints generales: raíz y autenticación." },
    { "name": "Empleados", "description": "Gestión de empleados." },
    { "name": "Departamentos", "description": "Gestión de departamentos." },
    { "name": "Contratos", "description": "Gestión de contratos." },
    { "name": "Productos", "description": "Consulta del inventario de productos." }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "Raíz de la API",
        "description": "Devuelve un mapa con todos los endpoints disponibles.",
        "security": [],
        "responses": {
          "200": {
            "description": "Mapa de rutas disponibles.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "body": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["General"],
        "summary": "Iniciar sesión",
        "description": "Autentica al usuario con credenciales (usuario + contraseña) o con un token existente. Devuelve un token de sesión.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "usuario": {
                    "type": "string",
                    "description": "Nombre de usuario. Requerido si no se envía token.",
                    "example": "jgarcia"
                  },
                  "pass": {
                    "type": "string",
                    "description": "Contraseña del usuario. Requerida si no se envía token.",
                    "example": "miContraseña123"
                  },
                  "keepSession": {
                    "type": "boolean",
                    "description": "Si es true, el token dura 24h. Si es false, dura 1h.",
                    "example": true
                  },
                  "token": {
                    "type": "string",
                    "description": "Token de sesión existente para renovarlo. Si se envía, no se necesitan usuario ni pass.",
                    "example": "abc123def456..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inicio de sesión correcto.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 201 },
                    "auth": {
                      "type": "object",
                      "properties": {
                        "authorized": { "type": "boolean", "example": true },
                        "username": { "type": "string", "example": "jgarcia" },
                        "id": { "type": "integer", "example": 5 },
                        "token": { "type": "string", "example": "abc123def456..." },
                        "department": { "type": "integer", "example": 2 }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales no proporcionadas.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } }
          },
          "404": {
            "description": "Credenciales incorrectas o token inválido.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorNotFound" } } }
          },
          "500": {
            "description": "Error interno del servidor.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } }
          }
        }
      }
    },
    "/empleados": {
      "get": {
        "tags": ["Empleados"],
        "summary": "Listado de empleados",
        "description": "Devuelve una lista paginada de empleados visibles. Si se pasa `id` como query param, devuelve el empleado concreto.",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "ID del empleado. Si se envía, devuelve solo ese empleado.",
            "required": false,
            "schema": { "type": "integer", "example": 5 }
          },
          {
            "name": "cantidad",
            "in": "query",
            "description": "Número de resultados por página.",
            "required": false,
            "schema": { "type": "integer", "example": 10 }
          },
          {
            "name": "pagina",
            "in": "query",
            "description": "Número de página (empieza en 0).",
            "required": false,
            "schema": { "type": "integer", "example": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de empleados o datos de uno concreto.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "pagina": { "type": "integer", "example": 0 },
                    "cantidad": { "type": "integer", "example": 10 },
                    "resultados": { "type": "integer", "example": 5 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Empleado" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "404": { "description": "Empleado no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorNotFound" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "post": {
        "tags": ["Empleados"],
        "summary": "Registrar o actualizar empleado",
        "description": "Si se envía `id` en el body, actualiza el empleado existente. Si no se envía `id`, registra un nuevo empleado junto con su usuario.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["nombre", "fecha_nacimiento", "telefono", "ID_contrato", "ID_departamento", "usuario", "contrasenia"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "ID del empleado. Si se envía, se actualizará ese empleado en lugar de crear uno nuevo.",
                    "example": 5
                  },
                  "nombre": {
                    "type": "string",
                    "description": "Nombre del empleado. Máximo 30 caracteres.",
                    "example": "Juan"
                  },
                  "apellidos": {
                    "type": "string",
                    "description": "Apellidos del empleado. Máximo 60 caracteres. Opcional.",
                    "example": "García López"
                  },
                  "fecha_nacimiento": {
                    "type": "string",
                    "format": "date",
                    "description": "Fecha de nacimiento del empleado.",
                    "example": "1990-05-15"
                  },
                  "telefono": {
                    "type": "string",
                    "description": "Teléfono del empleado. Máximo 12 caracteres.",
                    "example": "612345678"
                  },
                  "ID_contrato": {
                    "type": "integer",
                    "description": "ID del contrato asignado al empleado.",
                    "example": 3
                  },
                  "ID_departamento": {
                    "type": "integer",
                    "description": "ID del departamento asignado al empleado.",
                    "example": 2
                  },
                  "usuario": {
                    "type": "string",
                    "description": "Nombre de usuario. Máximo 16 caracteres. No se puede cambiar una vez creado.",
                    "example": "jgarcia"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email del empleado. Máximo 90 caracteres. Opcional.",
                    "example": "jgarcia@empresa.com"
                  },
                  "contrasenia": {
                    "type": "string",
                    "description": "Contraseña del empleado (se almacenará hasheada con scrypt).",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Empleado registrado o actualizado correctamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 201 },
                    "message": { "type": "string", "example": "Empleado registrado correctamente." }
                  }
                }
              }
            }
          },
          "400": { "description": "Faltan datos o son inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos suficientes.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": { "description": "Error al registrar el empleado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "delete": {
        "tags": ["Empleados"],
        "summary": "Eliminar empleado",
        "description": "Elimina un empleado y su usuario asociado de la base de datos en una transacción.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["usuario"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "ID del empleado a eliminar.",
                    "example": 5
                  },
                  "usuario": {
                    "type": "string",
                    "description": "Nombre de usuario del empleado a eliminar. Obligatorio.",
                    "example": "jgarcia"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Empleado eliminado correctamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 201 },
                    "message": { "type": "string", "example": "Empleado registrado correctamente." }
                  }
                }
              }
            }
          },
          "400": { "description": "ID inválido o usuario no proporcionado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos suficientes.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": { "description": "Error al eliminar el empleado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      }
    },
    "/departamentos": {
      "get": {
        "tags": ["Departamentos"],
        "summary": "Listado de departamentos",
        "description": "Devuelve una lista paginada de departamentos. Si se pasa `id` como query param, devuelve el departamento concreto.",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "ID del departamento. Si se envía, devuelve solo ese departamento.",
            "required": false,
            "schema": { "type": "integer", "example": 2 }
          },
          {
            "name": "cantidad",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 10 }
          },
          {
            "name": "pagina",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de departamentos o datos de uno concreto.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "pagina": { "type": "integer", "example": 0 },
                    "cantidad": { "type": "integer", "example": 10 },
                    "resultados": { "type": "integer", "example": 3 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Departamento" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "404": { "description": "Departamento no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorNotFound" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "post": {
        "tags": ["Departamentos"],
        "summary": "Crear o actualizar departamento",
        "description": "Crea un nuevo departamento. Si se envía `idAModificar`, actualiza el departamento existente con ese ID.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["nombre"],
                "properties": {
                  "nombre": {
                    "type": "string",
                    "description": "Nombre del departamento.",
                    "example": "Recursos Humanos"
                  },
                  "idAModificar": {
                    "type": "integer",
                    "description": "ID del departamento a modificar. Opcional; si no se envía, se crea uno nuevo.",
                    "example": 2
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Departamento creado o actualizado.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "idDepartamento": { "type": "integer", "example": 4 },
                    "message": { "type": "string", "example": "Departamento creado correctamente." }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "delete": {
        "tags": ["Departamentos"],
        "summary": "Eliminar departamento",
        "description": "Elimina un departamento por ID. Falla si hay empleados que dependen de él.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "ID del departamento a eliminar.",
                    "example": 2
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Departamento eliminado correctamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "message": { "type": "string", "example": "Departamento eliminado correctamente" }
                  }
                }
              }
            }
          },
          "400": { "description": "ID inválido o departamento no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": {
            "description": "Error interno o hay empleados dependientes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 500 },
                    "message": { "type": "string", "example": "Hay empleados que dependen de este Departamento. No se puede eliminar." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/contratos": {
      "get": {
        "tags": ["Contratos"],
        "summary": "Listado de contratos",
        "description": "Devuelve una lista paginada de contratos. Si se pasa `id` como query param, devuelve el contrato concreto.",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "ID del contrato. Si se envía, devuelve solo ese contrato.",
            "required": false,
            "schema": { "type": "integer", "example": 3 }
          },
          {
            "name": "cantidad",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 10 }
          },
          {
            "name": "pagina",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de contratos o datos de uno concreto.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "pagina": { "type": "integer", "example": 0 },
                    "cantidad": { "type": "integer", "example": 10 },
                    "resultados": { "type": "integer", "example": 4 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Contrato" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "404": { "description": "Contrato no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorNotFound" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "post": {
        "tags": ["Contratos"],
        "summary": "Crear o actualizar contrato",
        "description": "Crea un nuevo contrato. Si se envía `idAModificar`, actualiza el contrato existente con ese ID.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["salarioAnual", "horasAnuales"],
                "properties": {
                  "salarioAnual": {
                    "type": "number",
                    "description": "Salario anual del contrato. Debe ser mayor o igual a 0.",
                    "example": 24000
                  },
                  "horasAnuales": {
                    "type": "number",
                    "description": "Horas anuales del contrato. Debe ser mayor o igual a 0.",
                    "example": 1800
                  },
                  "idAModificar": {
                    "type": "integer",
                    "description": "ID del contrato a modificar. Opcional; si no se envía, se crea uno nuevo.",
                    "example": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contrato creado o actualizado.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "idContrato": { "type": "integer", "example": 7 },
                    "message": { "type": "string", "example": "Contrato creado correctamente." }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      },
      "delete": {
        "tags": ["Contratos"],
        "summary": "Eliminar contrato",
        "description": "Elimina un contrato por ID. Falla si hay empleados que dependen de él.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "ID del contrato a eliminar.",
                    "example": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contrato eliminado correctamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "message": { "type": "string", "example": "Contrato eliminado correctamente" }
                  }
                }
              }
            }
          },
          "400": { "description": "ID inválido o contrato no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "403": { "description": "Sin permisos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorForbidden" } } } },
          "500": {
            "description": "Error interno o hay empleados dependientes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 500 },
                    "message": { "type": "string", "example": "Hay empleados que dependen de este contrato. No se puede eliminar." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/productos": {
      "get": {
        "tags": ["Productos"],
        "summary": "Listado de productos",
        "description": "Devuelve una lista paginada de productos del inventario. Si se pasa `id` como query param, devuelve el producto concreto.",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "ID del producto. Si se envía, devuelve solo ese producto.",
            "required": false,
            "schema": { "type": "integer", "example": 1 }
          },
          {
            "name": "cantidad",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 10 }
          },
          {
            "name": "pagina",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "example": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos o datos de uno concreto.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "integer", "example": 200 },
                    "pagina": { "type": "integer", "example": 0 },
                    "cantidad": { "type": "integer", "example": 10 },
                    "resultados": { "type": "integer", "example": 8 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Producto" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Parámetros inválidos.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorBadRequest" } } } },
          "401": { "description": "Token no enviado o caducado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorUnauthorized" } } } },
          "404": { "description": "Producto no encontrado.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorNotFound" } } } },
          "500": { "description": "Error interno.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorServer" } } } }
        }
      }
    }
  }
}